{
  "productName": "CDJ Emulator",
  "version": "0.1.0",
  "identifier": "com.cdj-emulator.app",
  "build": {
    "frontendDist": "../../../../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../../../../ui && npm run dev",
    "beforeBuildCommand": "cd ../../../../ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CDJ Emulator",
        "width": 1200,
        "height": 780,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
